{
  "permissions": {
    "allow": [
      "Bash(unzip -p *)",
      "Bash(unzip -l *)",
      "Bash(mvn dependency:tree *)",
      "Bash(mvn dependency:analyze *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
