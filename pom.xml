								</requireReleaseDeps>
								<reactorModuleConvergence />
								<requirePluginVersions>
									<banSnapshots>false</banSnapshots>
								</requirePluginVersions>
							</rules>
						</configuration>
					</execution>
				</executions>
			</plugin>
		</plugins>
